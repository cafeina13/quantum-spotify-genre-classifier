# Copy this file to .env and fill in your IBM Quantum token.
# The .env file is gitignored — never commit your token.
#
# Get your token at: https://quantum.ibm.com/
# (Sign in → Account settings → API token)

IBM_QUANTUM_TOKEN=your_token_here

# Optional: override the default IBM backend from config.py
# IBM_BACKEND=ibm_brisbane
